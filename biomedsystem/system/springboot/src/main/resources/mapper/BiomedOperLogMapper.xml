<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mapper.BiomedOperLogMapper">
    <resultMap id="BiomedOperLogResultMap" type="com.example.entity.BiomedOperLog">
        <id column="id" property="id"/>
        <result column="sample_id" property="sampleId"/>
        <result column="oper_type" property="operType"/>
        <result column="oper_by" property="operBy"/>
        <result column="oper_time" property="operTime"/>
        <result column="content" property="content"/>
    </resultMap>

    <select id="selectAll" parameterType="com.example.entity.BiomedOperLog" resultMap="BiomedOperLogResultMap">
        SELECT * FROM biomed_oper_log
        <where>
            <if test="sampleId != null">
                AND sample_id = #{sampleId}
            </if>
            <if test="operType != null and operType != ''">
                AND oper_type = #{operType}
            </if>
        </where>
        ORDER BY oper_time DESC
    </select>

    <insert id="insert" parameterType="com.example.entity.BiomedOperLog" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO biomed_oper_log (sample_id, oper_type, oper_by, oper_time, content)
        VALUES (#{sampleId}, #{operType}, #{operBy}, NOW(), #{content})
    </insert>

    <delete id="deleteById" parameterType="java.lang.Long">
        DELETE FROM biomed_oper_log WHERE id = #{id}
    </delete>

    <select id="selectById" parameterType="java.lang.Long" resultMap="BiomedOperLogResultMap">
        SELECT * FROM biomed_oper_log WHERE id = #{id}
    </select>
</mapper>